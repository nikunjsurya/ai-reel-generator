# AI Reel Generator env template
# Copy to .env and fill in. .env is gitignored.
# n8n reads credentials from its own store, not from this file.
# This file is reference for local Python/CLI helpers and humans.

# ─── Telegram Bot API ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=paste_from_botfather
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
TELEGRAM_CHAT_ID=123456789
TELEGRAM_WEBHOOK_SECRET=generate_a_random_32char_string

# ─── Anthropic (Claude) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_RANK=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SCENE_PLAN=claude-sonnet-4-6

# ─── ElevenLabs ─────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_elevenlabs_...
ELEVENLABS_VOICE_ID=your_voice_id_here    # any ElevenLabs voice ID; create/clone at elevenlabs.io

# ─── Upload-Post (optional, Phase 4+ cross-platform publishing) ─────
UPLOAD_POST_API_KEY=
UPLOAD_POST_PROFILE_USERNAME=

# ─── Project paths ──────────────────────────────────────────────────
# Absolute path to this repo on your machine. Used as the Docker bind
# mount for n8n (mounts to /project inside the container) and as the
# write target for rendered MP4s.
PROJECT_PATH=/absolute/path/to/ai-reel-generator
OUTPUT_DIR=/absolute/path/to/ai-reel-generator/out

# ─── Render bridge ──────────────────────────────────────────────────
# Port the host-side render-bridge listens on. Default 5555. Workflows
# call http://host.docker.internal:<PORT> from inside the n8n container.
RENDER_BRIDGE_PORT=5555

# ─── Cost + performance guards ──────────────────────────────────────
MAX_COST_PER_RUN_USD=0.50
REEL_DURATION_SEC=90
HTTP_TIMEOUT_SEC=30
OG_IMAGE_MAX_BYTES=5242880
