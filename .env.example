# AI Reel Generator — env template
# Copy to .env and fill in. .env is gitignored.
# n8n reads credentials from its own store, not from this file.
# This file is reference for local Python/CLI helpers and humans.

# ─── Telegram Bot API ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=paste_from_botfather
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
TELEGRAM_CHAT_ID=123456789
TELEGRAM_WEBHOOK_SECRET=generate_a_random_32char_string

# ─── Anthropic (Claude) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_RANK=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SCENE_PLAN=claude-sonnet-4-6

# ─── ElevenLabs ─────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_elevenlabs_...
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb

# ─── Upload-Post (optional, Phase 4+) ───────────────────────────────
UPLOAD_POST_API_KEY=
UPLOAD_POST_PROFILE_USERNAME=

# ─── Shorts Factory paths ───────────────────────────────────────────
SHORTS_FACTORY_PATH=C:/Users/surya/Projects/shorts-factory
OUTPUT_DIR=C:/Users/surya/Projects/shorts-factory/out

# ─── Cost + performance guards ──────────────────────────────────────
MAX_COST_PER_RUN_USD=0.50
REEL_DURATION_SEC=90
HTTP_TIMEOUT_SEC=30
OG_IMAGE_MAX_BYTES=5242880
