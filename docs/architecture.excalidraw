      "link": null,
      "locked": false,
      "fontFamily": 2,
      "fontSize": 15,
      "text": "Zapier: charges per step, weak branching, no way to show 3 options for approval. Make.com: similar limits. Raw code:\nslower to debug, harder for the next person to take over.\nn8n wins: I can SEE the flow, every step has a sticky note, free, same setup I already use for another project\n(proven).",
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 12,
      "originalText": "Zapier: charges per step, weak branching, no way to show 3 options for approval. Make.com: similar limits. Raw code:\nslower to debug, harder for the next person to take over.\nn8n wins: I can SEE the flow, every step has a sticky note, free, same setup I already use for another project\n(proven).",
      "lineHeight": 1.25,
      "containerId": "el_Uzt0qcsjQPMXpR",
      "autoResize": false
    },
