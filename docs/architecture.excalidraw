    },
    {
      "id": "el_Nf4CC8YIthqvXU",
      "type": "text",
      "x": 440,
      "y": 6764,
      "width": 1120,
      "height": 156,
      "angle": 0,
      "strokeColor": "#1F2937",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1.5,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
