    {
      "id": "el_cbJucBD7ehnBKs",
      "type": "text",
      "x": 792,
      "y": 4298,
      "width": 936,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1F2937",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
