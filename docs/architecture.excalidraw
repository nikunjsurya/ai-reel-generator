      "boundElements": [],
      "updated": 1777146527408,
      "link": null,
      "locked": false,
      "fontFamily": 2,
      "fontSize": 15,
      "text": "ElevenLabs regular endpoint: gives you the MP3 but no word timings, so you'd need a 15-second extra step (Whisper) to\nsync captions. Azure TTS: robotic voice. OpenAI TTS: less natural in Indian English.\nElevenLabs with-timestamps wins: best voice quality AND word-by-word timing in one call. Costs 77% of the total bill,\nworth every cent.",
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 12,
      "originalText": "ElevenLabs regular endpoint: gives you the MP3 but no word timings, so you'd need a 15-second extra step (Whisper) to\nsync captions. Azure TTS: robotic voice. OpenAI TTS: less natural in Indian English.\nElevenLabs with-timestamps wins: best voice quality AND word-by-word timing in one call. Costs 77% of the total bill,\nworth every cent.",
      "lineHeight": 1.25,
      "containerId": "el_daZF40Rj3mrpyv",
      "autoResize": false
    },
