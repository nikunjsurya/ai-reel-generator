      "locked": false,
      "fontFamily": 2,
      "fontSize": 28,
      "text": "Three candidates, one human tap.  (The 10%.)",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 22,
      "originalText": "Three candidates, one human tap.  (The 10%.)",
      "lineHeight": 1.25,
