      "link": null,
      "locked": false,
      "fontFamily": 2,
      "fontSize": 15,
      "text": "A cheap cloud server (~$6/month) runs a free open-source AI\n(Llama or Gemma) that watches news feeds 24/7, drafts reel\ncandidates in the background, and queues them in Telegram. Zero\nAI API cost. Human only picks winners from a pre-filled queue.",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "originalText": "A cheap cloud server (~$6/month) runs a free open-source AI\n(Llama or Gemma) that watches news feeds 24/7, drafts reel\ncandidates in the background, and queues them in Telegram. Zero\nAI API cost. Human only picks winners from a pre-filled queue.",
      "lineHeight": 1.25,
      "containerId": null,
      "autoResize": false
    },
