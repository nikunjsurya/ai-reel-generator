      "locked": false,
      "fontFamily": 2,
      "fontSize": 15,
      "text": "Each reel option gets its own ID. Tap Approve A twice = instant\nreplay from cache (~15s). Tap B after A = fresh render, no conflict\nwith A. Re-sending the same topic within 24h returns the cached\npreview cards instantly.",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "originalText": "Each reel option gets its own ID. Tap Approve A twice = instant\nreplay from cache (~15s). Tap B after A = fresh render, no conflict\nwith A. Re-sending the same topic within 24h returns the cached\npreview cards instantly.",
      "lineHeight": 1.25,
      "containerId": null,
      "autoResize": false
    },
