      "link": null,
      "locked": false,
      "fontFamily": 2,
      "fontSize": 15,
      "text": "Slack: needs a company workspace, corporate friction. Discord: feels like a gamer community, not a work tool. Custom\nweb app: hours to build a login, hours to host.\nTelegram wins: users already have the app, zero onboarding, bots are free, buttons are built in, works from any phone\nanywhere.",
      "textAlign": "left",
      "verticalAlign": "middle",
      "baseline": 12,
      "originalText": "Slack: needs a company workspace, corporate friction. Discord: feels like a gamer community, not a work tool. Custom\nweb app: hours to build a login, hours to host.\nTelegram wins: users already have the app, zero onboarding, bots are free, buttons are built in, works from any phone\nanywhere.",
      "lineHeight": 1.25,
      "containerId": "el_0A1pRtmV3HvM9r",
      "autoResize": false
    },
